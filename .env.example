# ============================================================================
#  Apex Ride — environment variables
#
#  Business constants (brand name, contact details, fares, social links) are
#  NOT here — they live in `src/config/site.json`, which is plain public data
#  you can edit without touching code.
#
#  This file is reserved for values that are environment-specific or sensitive.
#  Copy it to `.env.local` and adjust per deployment.
# ============================================================================

# --- Where THIS deployment is hosted -----------------------------------------
# Used for canonical URLs, sitemap, robots and Open Graph tags. Overrides the
# canonical "url" in site.json (handy for preview/staging environments).
# If unset, the value in site.json is used.
NEXT_PUBLIC_SITE_URL=https://www.apexride.co.uk

# --- Secrets (examples; add as needed) ---------------------------------------
# Genuine secrets go here, never in site.json. Anything WITHOUT the
# NEXT_PUBLIC_ prefix stays server-side and is never sent to the browser.
#
# BOOKING_API_KEY=
# ANALYTICS_ID=
