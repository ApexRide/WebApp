# ============================================================================
#  Volt Cabs — site configuration
#  Copy this file to `.env.local` and edit the values. Everything the marketing
#  team is likely to change (company name, contact details, fares) lives here,
#  so no code changes are needed to update them.
#
#  NOTE: variables prefixed with NEXT_PUBLIC_ are exposed to the browser. That
#  is intentional here — this is all public marketing information.
# ============================================================================

# --- Where the site is hosted (used for canonical URLs, sitemap, OG tags) ---
NEXT_PUBLIC_SITE_URL=https://www.apexride.co.uk

# --- Brand / company identity ---
NEXT_PUBLIC_BRAND_NAME=APEX
NEXT_PUBLIC_COMPANY_NAME=Apex Ride
NEXT_PUBLIC_LEGAL_NAME=Apex Ride Ltd
NEXT_PUBLIC_FOUNDING_YEAR=2016

# --- Contact information ---
NEXT_PUBLIC_CONTACT_PHONE=0800 123 4567
NEXT_PUBLIC_CONTACT_EMAIL=ride@apexride.co.uk
NEXT_PUBLIC_OFFICE_ADDRESS=Apex House, 12 Whitworth Street
NEXT_PUBLIC_OFFICE_CITY=Manchester
NEXT_PUBLIC_OFFICE_POSTCODE=M1 3AL
NEXT_PUBLIC_OFFICE_COUNTRY=GB
NEXT_PUBLIC_OFFICE_LAT=53.4763
NEXT_PUBLIC_OFFICE_LNG=-2.2360

# --- Social profiles (leave blank to hide) ---
NEXT_PUBLIC_SOCIAL_TWITTER=https://twitter.com/apexride
NEXT_PUBLIC_SOCIAL_FACEBOOK=https://facebook.com/apexride
NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://instagram.com/apexride
NEXT_PUBLIC_TWITTER_HANDLE=@apexride

# --- Defaults (theme: system | light | dark) (lang: en | fr | de | ar) ---
NEXT_PUBLIC_DEFAULT_THEME=system
NEXT_PUBLIC_DEFAULT_LANG=en
NEXT_PUBLIC_SHOW_CITY_MARQUEE=true

# --- Currency used for fares ---
NEXT_PUBLIC_CURRENCY=GBP
NEXT_PUBLIC_CURRENCY_SYMBOL=£

# ----------------------------------------------------------------------------
#  Fare rates. Each vehicle tier has a base fare, a per-mile rate and a seat
#  count. The estimate shown is: base + (perMile * miles). Edit freely.
# ----------------------------------------------------------------------------
# Saloon
NEXT_PUBLIC_RATE_SALOON_BASE=3.20
NEXT_PUBLIC_RATE_SALOON_PER_MILE=1.75
NEXT_PUBLIC_RATE_SALOON_SEATS=4
# Estate
NEXT_PUBLIC_RATE_ESTATE_BASE=3.80
NEXT_PUBLIC_RATE_ESTATE_PER_MILE=2.05
NEXT_PUBLIC_RATE_ESTATE_SEATS=4
# MPV
NEXT_PUBLIC_RATE_MPV_BASE=4.60
NEXT_PUBLIC_RATE_MPV_PER_MILE=2.45
NEXT_PUBLIC_RATE_MPV_SEATS=6
# Executive
NEXT_PUBLIC_RATE_EXECUTIVE_BASE=6.50
NEXT_PUBLIC_RATE_EXECUTIVE_PER_MILE=3.20
NEXT_PUBLIC_RATE_EXECUTIVE_SEATS=4

# --- Estimate tuning ---
# Road-distance multiplier applied to straight-line distance (1 = as the crow flies)
NEXT_PUBLIC_ROAD_FACTOR=1.18
# Average journey speed in mph, used for the ETA estimate
NEXT_PUBLIC_AVG_SPEED_MPH=52
